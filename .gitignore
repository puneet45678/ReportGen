## .NET gitignore

# Build outputs
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# .NET build artifacts
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
project.lock.json
project.fragment.lock.json

# Testing
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
NUnit*.xml
coverage*.xml
coverage*.json
coverage*.cobertura.xml
.coverage/

# NuGet packages
packages/
.nuget/
*.nupkg
*.snupkg

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
._*
Thumbs.db
desktop.ini

# Generated report outputs in samples
samples/**/*.csv
samples/**/*.xlsx
samples/**/*.pdf
!samples/**/.gitkeep
